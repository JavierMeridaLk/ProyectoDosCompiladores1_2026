/* Sistema bancario simple */
TABLE cuentas COLUMNS titular=string, saldo=float, activa=boolean;

cuentas[titular="Empresa S.A.", saldo=15420.50, activa=True];
cuentas[titular="Juan Perez", saldo=100.00, activa=True];

/* Penalización por mantenimiento */
cuentas[saldo=85.00] IN 2;

/* Cierre de cuenta */
cuentas DELETE 2;

/* Ver saldos restantes */
cuentas.saldo;