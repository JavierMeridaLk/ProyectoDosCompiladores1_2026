/* ============================================
   pokedex.db — Base de datos de la Pokédex
   Tipos sincronizados con el lenguaje principal:
   int, string, float, boolean, number, double
   ============================================ */

/* Tabla principal de pokemones */
TABLE pokemon COLUMNS
    nombre=string,
    nivel=int,
    hp=int,
    ataque=int,
    defensa=int,
    tipo=string,
    imagen=string,
    activo=boolean;

/* Tabla de entrenadores */
TABLE entrenador COLUMNS
    nombre=string,
    medallas=int,
    region=string,
    activo=boolean;

/* Tabla de batallas */
TABLE batalla COLUMNS
    entrenador_id=int,
    pokemon_id=int,
    resultado=string,
    puntos=float,
    fecha=string;

/* Tabla de movimientos */
TABLE movimiento COLUMNS
    pokemon_id=int,
    nombre=string,
    poder=int,
    precision=int,
    tipo=string;

/* ── Insertar pokemones iniciales ── */
pokemon[nombre="Bulbasaur",  nivel=10, hp=45,  ataque=49,  defensa=49, tipo="Planta",    imagen="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/1.png",   activo=true];
pokemon[nombre="Charmander", nivel=12, hp=39,  ataque=52,  defensa=43, tipo="Fuego",     imagen="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/4.png",   activo=true];
pokemon[nombre="Squirtle",   nivel=11, hp=44,  ataque=48,  defensa=65, tipo="Agua",      imagen="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/7.png",   activo=true];
pokemon[nombre="Pikachu",    nivel=25, hp=35,  ataque=55,  defensa=40, tipo="Electrico", imagen="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/25.png",  activo=true];
pokemon[nombre="Mewtwo",     nivel=70, hp=106, ataque=110, defensa=90, tipo="Psiquico",  imagen="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/150.png", activo=false];
pokemon[nombre="Snorlax",    nivel=30, hp=160, ataque=110, defensa=65, tipo="Normal",    imagen="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/143.png", activo=false];

/* ── Insertar entrenadores ── */
entrenador[nombre="Ash",   medallas=8,  region="Kanto",   activo=true];
entrenador[nombre="Misty", medallas=5,  region="Cerulean", activo=true];
entrenador[nombre="Brock", medallas=10, region="Pewter",   activo=false];

/* ── Insertar batallas ── */
batalla[entrenador_id=1, pokemon_id=4, resultado="victoria", puntos=150.5,  fecha="2026-01-15"];
batalla[entrenador_id=1, pokemon_id=2, resultado="derrota",  puntos=50.0,   fecha="2026-01-16"];
batalla[entrenador_id=2, pokemon_id=3, resultado="victoria", puntos=120.75, fecha="2026-01-17"];
batalla[entrenador_id=1, pokemon_id=1, resultado="victoria", puntos=200.0,  fecha="2026-01-18"];

/* ── Insertar movimientos ── */
movimiento[pokemon_id=1, nombre="Placaje",      poder=40, precision=100, tipo="Normal"];
movimiento[pokemon_id=1, nombre="Latigazo",     poder=45, precision=100, tipo="Planta"];
movimiento[pokemon_id=2, nombre="Aranazo",      poder=40, precision=100, tipo="Normal"];
movimiento[pokemon_id=2, nombre="Ascuas",       poder=40, precision=100, tipo="Fuego"];
movimiento[pokemon_id=3, nombre="Placaje",      poder=40, precision=100, tipo="Normal"];
movimiento[pokemon_id=3, nombre="Pistola Agua", poder=40, precision=100, tipo="Agua"];
movimiento[pokemon_id=4, nombre="Impactrueno",  poder=40, precision=100, tipo="Electrico"];
movimiento[pokemon_id=4, nombre="Rayo",         poder=90, precision=100, tipo="Electrico"];
movimiento[pokemon_id=5, nombre="Psiquico",     poder=90, precision=100, tipo="Psiquico"];
movimiento[pokemon_id=5, nombre="Sombra Bola",  poder=80, precision=100, tipo="Fantasma"];

/* ── Consultas SELECT ── */
pokemon.nombre;
pokemon.nivel;
pokemon.tipo;
pokemon.imagen;
pokemon.activo;
entrenador.nombre;
entrenador.medallas;
batalla.resultado;
batalla.puntos;

/* ── Actualizaciones ── */
pokemon[nivel=26, hp=40] IN 4;
pokemon[nivel=13, ataque=56] IN 2;
entrenador[medallas=9] IN 1;
batalla[puntos=175.5] IN 1;

/* ── Eliminar registro de prueba ── */
batalla DELETE 2;